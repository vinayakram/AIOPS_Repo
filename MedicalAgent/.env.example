# Copy this file to .env and fill in your values

# Required: OpenAI API key for LLM generation
OPENAI_API_KEY=changeme

# OpenAI model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional: separate Azure OpenAI deployment for the AIOps LLM rate-limit scenario
LOW_RATE_LIMIT_OPENAI_API_KEY=
LOW_RATE_LIMIT_OPENAI_ENDPOINT=https://synapt-development-instance.openai.azure.com/
LOW_RATE_LIMIT_OPENAI_API_VERSION=2024-02-15-preview
LOW_RATE_LIMIT_OPENAI_DEPLOYMENT=low-ratelimit-gpt-4o-mini
LOW_RATE_LIMIT_OPENAI_MODEL=gpt-4o-mini
LOW_RATE_LIMIT_REQUESTS_PER_MINUTE=10

# Optional: PubMed API key (increases rate limit from 3 to 10 requests/sec)
PUBMED_API_KEY=changeme

# Required by NCBI: your email for API usage tracking
PUBMED_EMAIL=your-email@example.com

# JWT secret key - change this in production!
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Embedding model (change for better quality: "all-mpnet-base-v2")
EMBEDDING_MODEL=all-MiniLM-L6-v2

# PageRank weight (0-1): higher = more PageRank influence, lower = more similarity
PAGERANK_ALPHA=0.4

# AIops Telemetry server. In Docker Compose this is overridden to host.docker.internal.
AIOPS_ENABLED=true
AIOPS_SERVER_URL=http://localhost:7000

# Pod resource guard demo. When breached, normal app access returns:
# "application is not reachable".
POD_CPU_THRESHOLD_ENABLED=true
POD_CPU_THRESHOLD_PERCENT=90
POD_MEMORY_THRESHOLD_ENABLED=true
POD_MEMORY_THRESHOLD_PERCENT=90
POD_THRESHOLD_TELEMETRY_MIN_INTERVAL_SECONDS=1

# Comma-separated allowed origins (use * for local dev only)
CORS_ORIGINS=*

# Dependent cascade demo agent. This agent runs as triage-agent in docker-compose
# and calls sample-agent so MCP/RCA can correlate cross-service failures.
DEPENDENT_AGENT_NAME=triage-agent
UPSTREAM_SERVICE_NAME=sample-agent
SAMPLE_AGENT_URL=http://medical-rag-pod:8002
UPSTREAM_TIMEOUT_SECONDS=3
