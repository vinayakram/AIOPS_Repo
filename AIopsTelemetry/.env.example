# ── AIops Server ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

AIOPS_HOST=0.0.0.0
AIOPS_PORT=7000
AIOPS_DATABASE_URL=sqlite:///./aiops.db
AIOPS_API_KEY=                          # leave blank to disable auth

# Issue detection thresholds (optional overrides)
AIOPS_HIGH_LATENCY_MULTIPLIER=3.0
AIOPS_NFR_RESPONSE_TIME_TARGET_MS=5000.0
AIOPS_NFR_CHECK_WINDOW_MINUTES=10

# ── Langfuse (optional) ───────────────────────────────────────────────────────
AIOPS_LANGFUSE_SECRET_KEY=
AIOPS_LANGFUSE_PUBLIC_KEY=
AIOPS_LANGFUSE_HOST=https://cloud.langfuse.com

# ── OpenAI (used by modifier_agent) ──────────────────────────────────────────
AIOPS_OPENAI_API_KEY=

# ── Anthropic (used by autofix_agent / Claude Code CLI) ──────────────────────
ANTHROPIC_API_KEY=

# Agent process directories (override if not co-located with this repo)
WEB_SEARCH_AGENT_DIR=
SAMPLE_AGENT_DIR=
