flowchart TB
  %% ==============================================
  %% PROFESSIONAL ARCHITECTURE VIEW (STATIC SYSTEM)
  %% ==============================================

  %% External / Users
  USER["End Users\nClinical query + Ops review"]
  LANGFUSE[("Langfuse Cloud")]
  PROM[("Prometheus")]
  GIT[("GitHub / Git Repos")]

  %% Domain A: AI Application Plane
  subgraph APP ["A) AI Application Plane"]
    MA_API["SampleAgent API (:8000)\nFastAPI + JWT"]
    MA_PIPE["RAG Engine\nPubMed -> Embeddings -> FAISS -> Re-rank -> LLM"]
    MA_TR["Telemetry Forwarder\nbackend/tracing/aiops_client.py"]
  end

  %% Domain B: Observability + Incident Plane
  subgraph OBS ["B) Observability & Incident Plane"]
    AT_ING["Ingest API (:7000)\nPOST /api/ingest/trace"]
    AT_DB[("aiops.db\ntraces | spans | issues | issue_analyses | rules")]
    AT_ESC["Escalation Engine\n30s periodic loop"]
    AT_DET["NFR Rule Detector\nLatency/Error/LLM/Timeout/Token rules"]
    AT_INC["Incidents API\nGET /api/v1/incidents"]
    AT_RCA["RCA Client\nrequest_rca(issue_id)"]
    AT_DASH["AIOpsTelemetry Dashboard + APIs"]
    AT_REMP["Remediation Proxy API\n/api/remediation/issues/{id}/*"]
  end

  %% Domain C: Investigation / RCA Plane
  subgraph RCA ["C) Investigation & RCA Plane"]
    INV_POLL["AIOps Poller (:8000)\nGET incidents + dedupe"]
    INV_ORCH["Orchestrator\n5-agent pipeline"]
    INV_NORM["Normalization Agent"]
    INV_CORR["Correlation Agent"]
    INV_EA["Error Analysis Agent"]
    INV_RCA["RCA Agent"]
    INV_REC["Recommendation Agent"]
    INV_DB[("investigations.db\ntrace_results + per-agent IO")]
    INV_API["Analyze API\nPOST /api/v1/analyze"]
  end

  %% Domain D: Remediation Plane
  subgraph REM ["D) Automated Remediation Plane"]
    RM_API["AIOPS Service (:8005)\nIssue workflow APIs"]
    RM_STATE[("runs/<issue_id>/\nplan, impl, diff, tests, artifacts")]
    RM_CODEX["Codex CLI Execution\nplan + implementation"]
    RM_PR["PR/Branch Delivery"]
  end

  %% User interactions
  USER --> MA_API
  USER --> AT_DASH

  %% SampleAgent internals
  MA_API --> MA_PIPE
  MA_PIPE -. trace/span export .-> LANGFUSE
  MA_API --> MA_TR

  %% Data plane flow
  MA_TR -->|"Telemetry payload\n(trace+spans)"| AT_ING
  AT_ING --> AT_DB
  AT_DB --> AT_ESC
  AT_ESC --> AT_DET
  AT_DET -->|"Create/Update Issues"| AT_DB
  AT_DB --> AT_INC

  %% RCA triggering options
  AT_ESC --> AT_RCA
  AT_RCA -->|"POST /api/v1/analyze"| INV_API
  INV_API --> INV_ORCH
  AT_INC --> INV_POLL
  INV_POLL --> INV_ORCH

  %% RCA pipeline composition
  INV_ORCH --> INV_NORM --> INV_CORR --> INV_EA --> INV_RCA --> INV_REC
  INV_ORCH --> INV_DB

  %% Investigative data sources
  INV_NORM -. traces/logs .-> LANGFUSE
  INV_CORR -. traces/logs .-> LANGFUSE
  INV_EA -. traces/logs .-> LANGFUSE
  INV_RCA -. traces/logs .-> LANGFUSE

  INV_NORM -. metrics .-> PROM
  INV_CORR -. metrics .-> PROM
  INV_EA -. metrics .-> PROM
  INV_RCA -. metrics .-> PROM

  %% RCA result back to telemetry store
  INV_ORCH -->|"RCA + recommendations JSON"| AT_DB

  %% Remediation control plane
  AT_DASH --> AT_REMP
  AT_REMP -->|"Proxy workflow calls"| RM_API
  RM_API --> RM_STATE
  RM_API --> RM_CODEX
  RM_CODEX --> RM_PR
  RM_PR --> GIT

  %% Style
  classDef ext fill:#fff7e6,stroke:#b26b00,stroke-width:1px,color:#222;
  classDef svc fill:#e8f4ff,stroke:#1f6fb2,stroke-width:1px,color:#0b2a44;
  classDef db fill:#f3f0ff,stroke:#5f3dc4,stroke-width:1px,color:#2c2463;
  classDef ctrl fill:#eafbea,stroke:#2b8a3e,stroke-width:1px,color:#1f4f2a;

  class USER,LANGFUSE,PROM,GIT ext;
  class MA_API,MA_PIPE,MA_TR,AT_ING,AT_ESC,AT_DET,AT_INC,AT_RCA,AT_DASH,AT_REMP,INV_POLL,INV_ORCH,INV_NORM,INV_CORR,INV_EA,INV_RCA,INV_REC,INV_API,RM_API,RM_CODEX,RM_PR svc;
  class AT_DB,INV_DB,RM_STATE db;
